{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jy-downloader",
  "version": "0.1.0",
  "identifier": "cn.jianying-utils.jy-downloader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "jy-downloader",
        "width": 1040,
        "height": 720,
        "minWidth": 860,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
